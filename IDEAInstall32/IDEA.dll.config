            </setting>
            <setting name="ConnectionType" serializeAs="String">
                <value>XML</value>
            </setting>
            <setting name="Assistant" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="ArchimAid" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="DatAid" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="Deduplicator" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="FormFactory" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="PackageHelper" serializeAs="String">
