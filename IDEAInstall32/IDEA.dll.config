            <setting name="ArchiMateHelper" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="XSDHelper" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="XMLFile" serializeAs="String">
                <value/>
            </setting>
            <setting name="StatementsTable" serializeAs="String">
                <value/>
            </setting>
            <setting name="DocumentImport" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="SolutionWizard" serializeAs="String">
